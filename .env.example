# Frontend's own origin — used for absolute URLs in metadata, OG
# tags, etc. Set this to the public URL the app is deployed to.
NEXT_PUBLIC_API_URL=http://localhost:3000

# Express backend base URL. The Next.js proxy routes under
# `app/api/*` forward to this with the user's session cookie.
NEXT_PUBLIC_BACKEND_API_URL=http://localhost:3040
